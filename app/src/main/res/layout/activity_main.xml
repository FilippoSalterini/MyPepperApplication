<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CAMERA FULLSCREEN -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/ivCameraPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#111111"
            android:scaleType="fitCenter"
            android:visibility="visible" />

        <com.example.mypepperapplication.views.BoundingBoxOverlayView
            android:id="@+id/overlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

    </FrameLayout>

    <!-- TOP CONTROLS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btnSnapshot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Snapshot" />

        <Button
            android:id="@+id/btnTrack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track Person" />
    </LinearLayout>

    <!-- WARNING -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="80dp"
        android:background="#AAFFF3CD"
        android:padding="8dp"
        android:text="@string/if_the_controls_do_not_respond_exit_the_app_and_re_enter"
        android:textColor="#856404"
        android:textSize="11sp"
        android:textStyle="bold" />

    <!-- OPEN CONTROLLER BUTTON -->
    <Button
        android:id="@+id/btnToggleControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="Open Controller" />

    <!-- CONTROLLER PANEL -->
    <LinearLayout
        android:id="@+id/controllerContainer"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_gravity="bottom"
        android:background="#DD222222"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <!-- FORWARD -->
        <Button
            android:id="@+id/btnForward"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="↑"
            android:textSize="28sp" />

        <!-- CENTER -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnLeft"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="⟲"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:backgroundTint="#F44336"
                android:text="STOP"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnRight"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="⟳"
                android:textSize="24sp" />
        </LinearLayout>

        <!-- BACKWARD -->
        <Button
            android:id="@+id/btnBackward"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:text="↓"
            android:textSize="28sp" />

    </LinearLayout>

</FrameLayout>